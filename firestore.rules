rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // PROYECTO APAGADO (2026-06-10): Escuela Dominical se unificó en la app Iglesia
    // (proyecto hombres-de-verdad, hdv.web.app/escuela/). Los datos se migraron y este
    // proyecto queda como respaldo CONGELADO: acceso denegado a todo. Reglas previas en
    // firestore.rules.bak-pre-apagado. Para reactivar, restaurar esas reglas y desplegar.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
